#!/bin/bash
#
# Record the current remaining battery percentage(s).
#
# Syntax:  record-battery-levels [event]
#
# Example:  record-battery-levels shutdown
#
# Battery levels are recorded to ~/battery-levels.txt.  
# If an event is given it is recorded first in the format:
# <timestamp> <event>
# Thereafter, each battery is recorded in the format:
# <timestamp> <battery device> <remaining charge percentage>

EVENT="$1"
RECORD_FILE=~/battery-levels.txt

battery-levels "$EVENT" >> $RECORD_FILE
